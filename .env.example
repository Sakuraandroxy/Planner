# Copy this file to .env and fill in your own API settings.
# Never commit .env or real API keys.

# ===== VLM API =====
PLANNER_BASE_URL=https://api.example.com/v1        # OpenAI-compatible API base URL, e.g. https://api.openai.com/v1
PLANNER_API_KEY=your_api_key_here                  # Your API key; do not commit real keys
PLANNER_MODEL_NAME=mimo-v2.5                       # Multimodal model name, e.g. mimo-v2.5 / step-3.5-flash-2603 / step-3.7-flash
PLANNER_THINKING_MODE=disabled                     # MiMo thinking mode: disabled=off; default=do not send thinking parameter
PLANNER_REASONING_EFFORT=default                   # Step reasoning effort: low=fast/low-token; medium=balanced if supported; high=stronger/slower; default=do not send
PLANNER_ENABLE_THINKING=false                      # Step thinking switch: false=disable thinking; true=enable thinking; default=do not send
PLANNER_WARMUP_ENABLED=1                           # Send one tiny API request at startup to reduce first-step cold start: 1=on, 0=off

# ===== Web / Runtime =====
WEB_PORT=5000                                      # Web dashboard port
MAX_STEPS=20                                       # Max closed-loop steps per task

# ===== Planner Output =====
PLANNER_ACTION_MODE=value                          # Action mode: atomic=discrete actions; value=actions with numeric values
PLANNER_CANDIDATE_COUNT=5                          # Number of candidate trajectories generated each step
PLANNER_MAX_TRAJECTORY_LENGTH=5                    # Max action count per candidate trajectory
PLANNER_MAX_TOKENS=8192                            # Max completion tokens for planning VLM output
PLANNER_TEMPERATURE=0.8                            # VLM sampling temperature

# ===== Motion Safety =====
PLANNER_MAX_FORWARD_STEP=inf                       # Temporary: no hard forward clamp; set a number like 20.0 to re-enable
PLANNER_MAX_TRACKING_YAW_STEP_DEG=inf              # Temporary: no hard yaw clamp; set a number like 15.0 to re-enable
PLANNER_VELOCITY=0.5                               # AirSim movement velocity, in m/s

# ===== Perception =====
PLANNER_TARGET_DEPTH_ENABLED=1                     # Enable target-bbox depth estimation: 1=on, 0=off
PLANNER_SCENE_OBSTACLE_PLANNING_ENABLED=1          # Detect target+obstacles first, compute depths, then let VLM plan around them
PLANNER_CAPTURE_INTERVAL=0.1                       # RGB/background capture interval, in seconds
PLANNER_DEPTH_PREVIEW_INTERVAL=2.0                 # Frontend depth preview refresh interval, in seconds
PLANNER_STARTUP_CAPTURE_ENABLED=1                  # Capture one RGB+depth frame at startup for frontend and Step-1 cache
PLANNER_FRAME_CACHE_MAX_AGE=10.0                   # Max age in seconds for reusing startup/idle frame on Step 1

# ===== Context Memory =====
PLANNER_CONTEXT_ENABLED=0                          # Lightweight context: target memory + task state only
PLANNER_CONTEXT_MAX_STEPS=5                        # Number of executed-step summaries kept if context prompt injection is enabled
PLANNER_CONTEXT_CAMERA_FOV_DEG=90.0                # Front camera horizontal FOV used to convert bbox center to target bearing
PLANNER_CONTEXT_WORLD_POS_UPDATE_ALPHA=0.35        # Smoothing factor for target world-position memory; higher trusts latest depth more
PLANNER_CONTEXT_ARRIVAL_DEPTH=5.0                  # Arrival radius passed to VLM prompt; not handled by ContextManager
PLANNER_APPROACH_STOP_MARGIN=1.0                   # Planning stop margin in meters; action distance should use target_depth minus this margin, not arrival radius

# ===== Target Identity Lock =====
PLANNER_TARGET_IDENTITY_ENABLED=1                   # Lock first target instance; reject later same-class targets far from locked world position
PLANNER_TARGET_IDENTITY_WORLD_TOLERANCE_ABS=15.0    # Minimum world-position acceptance radius in meters for matching the locked target
PLANNER_TARGET_IDENTITY_WORLD_TOLERANCE_RATIO=0.35  # Extra radius ratio based on target depth to absorb depth-map noise
PLANNER_TARGET_IDENTITY_ARRIVAL_RADIUS=6.0          # Complete the task if the drone is within this radius from the locked target when target is not visible
PLANNER_TARGET_IDENTITY_UPDATE_ALPHA=0.35           # Smoothing factor for locked target world position; higher trusts latest observation more

# ===== Lost Target Relocalizer =====
PLANNER_RELOCALIZER_ENABLED=1                      # Enable independent 4-view relocalization when current frame has no target
PLANNER_RELOCALIZER_VIEW_COUNT=4                   # Number of in-place panorama views to capture
PLANNER_RELOCALIZER_YAW_STEP_DEG=90.0              # Yaw angle between views; 4 x 90deg covers one full turn
PLANNER_RELOCALIZER_SETTLE_SECONDS=0.3             # Wait time after each rotation before capturing the next view
PLANNER_RELOCALIZER_CONFIDENCE_THRESHOLD=0.5       # Treat relocalizer result below this confidence as not found
PLANNER_RELOCALIZER_MAX_TOKENS=1024                # Max completion tokens for relocalizer multi-candidate JSON response
