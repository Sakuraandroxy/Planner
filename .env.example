# Copy this file to .env and fill in your own API settings.
# Never commit .env or real API keys.

# ===== VLM API =====
PLANNER_BASE_URL=https://api.example.com/v1        # OpenAI-compatible API base URL, e.g. https://api.openai.com/v1
PLANNER_API_KEY=your_api_key_here                  # Your API key; do not commit real keys
PLANNER_MODEL_NAME=mimo-v2.5                       # Multimodal model name, e.g. mimo-v2.5 / step-3.5-flash-2603 / step-3.7-flash
PLANNER_THINKING_MODE=disabled                     # MiMo thinking mode: disabled=off; default=do not send thinking parameter
PLANNER_REASONING_EFFORT=default                   # Step reasoning effort: low=fast/low-token; medium=balanced if supported; high=stronger/slower; default=do not send
PLANNER_ENABLE_THINKING=false                      # Step thinking switch: false=disable thinking; true=enable thinking; default=do not send
PLANNER_WARMUP_ENABLED=1                           # Send one tiny API request at startup to reduce first-step cold start: 1=on, 0=off

# ===== Web / Runtime =====
WEB_PORT=5000                                      # Web dashboard port
MAX_STEPS=20                                       # Max closed-loop steps per task

# ===== Planner Output =====
PLANNER_ACTION_MODE=value                          # Action mode: atomic=discrete actions; value=actions with numeric values
PLANNER_CANDIDATE_COUNT=5                          # Number of candidate trajectories generated each step
PLANNER_MAX_TRAJECTORY_LENGTH=5                    # Max action count per candidate trajectory
PLANNER_MAX_TOKENS=8192                            # Max completion tokens for planning VLM output
PLANNER_TEMPERATURE=0.8                            # VLM sampling temperature

# ===== Motion Safety =====
PLANNER_MAX_FORWARD_STEP=10.0                      # Max distance for one forward action, in meters
PLANNER_MAX_TRACKING_YAW_STEP_DEG=10.0             # Max single yaw turn when target is visible, in degrees
PLANNER_VELOCITY=0.5                               # AirSim movement velocity, in m/s

# ===== Perception =====
PLANNER_TARGET_DEPTH_ENABLED=1                     # Enable target-bbox depth estimation: 1=on, 0=off
PLANNER_CAPTURE_INTERVAL=0.1                       # RGB/background capture interval, in seconds
PLANNER_DEPTH_PREVIEW_INTERVAL=2.0                 # Frontend depth preview refresh interval, in seconds

# ===== Context Memory =====
PLANNER_CONTEXT_ENABLED=1                          # Enable structured target/task/search/obstacle memory: 1=on, 0=off
PLANNER_CONTEXT_REUSE_BBOX_ENABLED=1               # Reuse recent target bbox and recompute current depth when motion is small: 1=on, 0=off
PLANNER_CONTEXT_LOCAL_FORWARD_ENABLED=1            # Skip planning API and generate local forward segments when target is far and depth corridor is safe
PLANNER_CONTEXT_RECOVERY_ENABLED=1                 # Use target/search memory for short target-loss recovery yaw actions
PLANNER_CONTEXT_MAX_STEPS=5                        # Number of executed-step summaries kept in compact VLM context
PLANNER_CONTEXT_BBOX_REUSE_MAX_STEPS=1             # Max step age for bbox reuse; conservative default avoids stale boxes
PLANNER_CONTEXT_BBOX_REUSE_MAX_FORWARD=2.0         # Max recent forward distance in meters allowed before bbox reuse is disabled
PLANNER_CONTEXT_DEPTH_JUMP_RATIO=1.5               # Reject reused bbox when current depth suddenly becomes much larger than memory
PLANNER_CONTEXT_SWITCH_DEPTH_RATIO=0.6             # Reject suspicious target switch if new target depth differs too much from recent memory
PLANNER_CONTEXT_SWITCH_GUARD_STEPS=3               # Number of recent steps where target-switch guard is active
PLANNER_CONTEXT_MAX_LOST_BEFORE_REDETECT=2         # Lost frames handled by recovery memory before allowing full redetection
PLANNER_CONTEXT_LOCAL_FORWARD_MIN_DEPTH=20.0       # Target depth threshold for local segmented forward without planning API
PLANNER_CONTEXT_LOCAL_FORWARD_MIN_ACTION=2.0       # Minimum local forward distance; below this, use VLM planning instead
PLANNER_CONTEXT_GOAL_SAFETY_MARGIN=2.0             # Stop this many meters before target when local forward is generated
PLANNER_CONTEXT_OBSTACLE_MIN_SAFE_DEPTH=4.0        # If local corridor 10th-percentile depth is below this, mark path blocked
PLANNER_CONTEXT_OBSTACLE_SAFETY_MARGIN=2.0         # Keep this many meters before nearest local obstacle in forward corridor
PLANNER_CONTEXT_SEARCH_YAW_STEP_DEG=15.0           # Yaw step used by context recovery/search actions
PLANNER_CONTEXT_ARRIVAL_DEPTH=5.0                  # Stop when target median depth is at or below this distance, in meters
PLANNER_CONTEXT_FRONT_CORRIDOR_HALF_WIDTH=0.03     # Front safety corridor half width in normalized depth-image x; 0.03 means x=47%~53%
PLANNER_CONTEXT_FRONT_CORRIDOR_Y_MIN=0.45          # Front safety corridor top y ratio in depth image
PLANNER_CONTEXT_FRONT_CORRIDOR_Y_MAX=0.60          # Front safety corridor bottom y ratio in depth image
PLANNER_CONTEXT_TARGET_CORRIDOR_HALF_WIDTH=0.05    # Target-direction corridor half width around target center x; 0.05 means ±5%
PLANNER_CONTEXT_TARGET_CORRIDOR_Y_MIN=0.45         # Target-direction safety corridor top y ratio in depth image
PLANNER_CONTEXT_TARGET_CORRIDOR_Y_MAX=0.65         # Target-direction safety corridor bottom y ratio in depth image
PLANNER_CONTEXT_CAMERA_FOV_DEG=90.0                # Front camera horizontal FOV used to convert bbox center to target bearing
PLANNER_CONTEXT_EXPECTED_DEPTH_ABS_TOLERANCE=5.0   # Accept target if motion-compensated depth error is within this many meters
PLANNER_CONTEXT_EXPECTED_DEPTH_RATIO_TOLERANCE=0.25 # Also allow depth error up to this ratio of previous target depth
PLANNER_CONTEXT_EXPECTED_DEPTH_SOFT_MULTIPLIER=1.8 # Allow direction-consistent candidates within tolerance*this multiplier
PLANNER_CONTEXT_EXPECTED_DEPTH_HARD_MULTIPLIER=2.5 # Reject candidates beyond tolerance*this multiplier even if direction looks similar
PLANNER_CONTEXT_DIRECTION_TOLERANCE_DEG=35.0       # Accept/relocalize candidate if world-yaw is within this angle from target memory
PLANNER_CONTEXT_CANDIDATE_ANCHOR_MIN_SCORE=0.55    # Minimum candidate score needed to use it as relocalization scan anchor
